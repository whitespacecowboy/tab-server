{
	"manifest_version": 2,
	"name": "Tab Created Listener",
	"version": "1.0.0",
	"description": "Listens for tab created, deleted, replaced, and updated events.",

	"browser_specific_settings": {
		"gecko": {
			"id": "tab-event-listener@example.com",
			"strict_min_version": "57.0"
		}
	},

	"permissions": [
		"tabs"
  ],

  "background": {
	  "scripts": ["main.js"],
	  "type": "module"
  }
}
